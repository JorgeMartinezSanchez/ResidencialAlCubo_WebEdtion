<!-- src/entity/booking/ui/booking-card/booking-card.hbs -->
<div class="booking-card" data-booking-id="{{id}}">
    <div class="booking-card__header">
        <div class="booking-card__room">
            <span class="booking-card__room-number">Room {{roomNumber}}</span>
            <span class="booking-card__room-type">({{roomTypeName}})</span>
        </div>
        <div class="booking-card__status {{statusClass}}">
            {{status}}
        </div>
    </div>
    
    <div class="booking-card__dates">
        <div class="booking-card__date-range">
            <span class="booking-card__date-label">Starting Date</span>
            <span class="booking-card__date-value">{{startDate}}</span>
        </div>
        <div class="booking-card__date-range">
            <span class="booking-card__date-label">Ending Date</span>
            <span class="booking-card__date-value">{{endDate}}</span>
        </div>
    </div>
    
    <div class="booking-card__footer">
        <span class="booking-card__total-label">Total:</span>
        <span class="booking-card__total">
            ${{total}}
            <span class="booking-card__total-currency">USD</span>
        </span>
    </div>

    {{#ifEquals status "pending"}}
        <button class="booking-card__set-as-active">Set As Active</button>
    {{/ifEquals}}

    {{#ifEquals status "active"}}
        <button class="booking-card__set-as-finished">Finish</button>
    {{/ifEquals}}

    {{#ifNotEquals status "cancelled"}}
        <button class="booking-card__cancel-booking">Cancel</button>
    {{/ifNotEquals}}

</div>